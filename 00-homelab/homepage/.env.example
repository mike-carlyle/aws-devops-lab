# Copy to .env in this directory and fill in the values.
# .env is gitignored, should be chmod 600.

# AdGuard admin login (same as you use for the AdGuard web UI)
HOMEPAGE_VAR_ADGUARD_USERNAME=mike
HOMEPAGE_VAR_ADGUARD_PASSWORD=

# Jellyfin API key (generate in Jellyfin UI: Dashboard > API Keys > +)
HOMEPAGE_VAR_JELLYFIN_API_KEY=

# Portainer access token (generate in Portainer UI: My Account > Access tokens > Add)
HOMEPAGE_VAR_PORTAINER_TOKEN=

# Duplicati web UI password (the strong random one we set)
HOMEPAGE_VAR_DUPLICATI_PASSWORD=
