# Copy this file to .env in the same directory and fill in the values.
# .env is gitignored and should never be committed.

# Duplicati web UI password. Generate with: openssl rand -base64 24
DUPLICATI__WEBSERVICE_PASSWORD=

# Duplicati config database encryption key.
# Must remain stable across container restarts or the existing config cannot be decrypted.
# Generate once with: openssl rand -hex 32
SETTINGS_ENCRYPTION_KEY=
