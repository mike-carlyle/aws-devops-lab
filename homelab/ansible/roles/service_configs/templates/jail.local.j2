# Managed by Ansible — do not edit by hand.
#
# fail2ban sshd jail with LAN + Tailscale allowlist. Uses iptables-multiport
# action; the container runs with host network mode + NET_ADMIN so it can
# manipulate the host firewall directly.

[DEFAULT]
# Ban for 1 hour after 5 failures within 10 minutes
bantime  = 1h
findtime = 10m
maxretry = 5

# Never ban LAN or Tailscale clients
# {{ tailscale_cidr }} is the Tailscale CGNAT range
ignoreip = 127.0.0.1/8 ::1 {{ lan_cidr }} {{ tailscale_cidr }}

# Use iptables for banning (host network mode + NET_ADMIN gives access)
banaction = iptables-multiport
backend   = auto

[sshd]
enabled  = true
port     = ssh
logpath  = /var/log/auth.log
action   = iptables-multiport[name=sshd, port="ssh", protocol=tcp, chain=INPUT]
