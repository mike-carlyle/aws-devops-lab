# Copy to .env and fill in the bcrypt hash for the 'mike' user.
# .env should be chmod 600.
#
# Generate the hash interactively (will prompt for your password twice):
#   docker run --rm -it caddy:latest caddy hash-password
#
# IMPORTANT: wrap the hash value in single quotes so the $ characters
# in the bcrypt output are not interpreted by docker-compose.

BASIC_AUTH_HASH='REPLACE_WITH_BCRYPT_HASH'
